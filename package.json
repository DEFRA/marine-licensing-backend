{
  "name": "marine-licensing-backend",
  "version": "0.0.0",
  "description": "marine-licensing-backend",
  "main": "src/index.js",
  "type": "module",
  "engines": {
    "node": ">=22.20.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "docker:dev": "npm run dev",
    "dev": "NODE_ENV=development npm run server:watch",
    "dev:debug": "NODE_ENV=development npm run server:debug",
    "format": "prettier --write \"**/*.{cjs,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{cjs,js,json,md}\"",
    "git:pre-commit-hook": "npm run format:check && npm run lint",
    "postinstall": "npm run setup:husky",
    "lint": "eslint --cache --cache-strategy content \"**/*.{cjs,js}\"",
    "lint:fix": "npm run lint -- --fix",
    "postversion": "git add package.json package-lock.json && git commit -m $npm_package_version",
    "test": "TZ=UTC vitest run --coverage",
    "test:watch": "TZ=UTC vitest",
    "server:watch": "nodemon --ext js,json --legacy-watch ./src",
    "server:debug": "nodemon --inspect-brk=0.0.0.0 --ext js,json --legacy-watch ./src",
    "start": "NODE_ENV=production node --use-strict .",
    "setup:husky": "node -e \"try { (await import('husky')).default() } catch (e) { if (e.code !== 'ERR_MODULE_NOT_FOUND') throw e }\" --input-type module",
    "migrate:create": "migrate-mongo create",
    "migrate:up": "migrate-mongo up",
    "migrate:down": "migrate-mongo down",
    "migrate:status": "migrate-mongo status"
  },
  "author": "Defra DDTS",
  "license": "OGL-UK-3.0",
  "dependencies": {
    "@arcgis/core": "5.0.15",
    "@aws-sdk/client-s3": "^3.1029.0",
    "@aws-sdk/credential-providers": "3.1026.0",
    "@defra/cdp-auditing": "0.6.0",
    "@defra/hapi-secure-context": "0.4.0",
    "@defra/hapi-tracing": "1.30.0",
    "@elastic/ecs-pino-format": "1.5.0",
    "@esri/arcgis-rest-feature-service": "4.10.1",
    "@hapi/boom": "10.0.1",
    "@hapi/hapi": "21.4.8",
    "@hapi/wreck": "18.1.0",
    "@terraformer/arcgis": "2.1.2",
    "@tmcw/togeojson": "^7.1.2",
    "@turf/turf": "7.3.4",
    "adm-zip": "^0.5.17",
    "aws-embedded-metrics": "4.2.1",
    "aws4": "1.13.2",
    "convict": "6.2.5",
    "convict-format-with-validator": "6.2.0",
    "date-fns": "4.1.0",
    "dotenv": "17.4.1",
    "global-agent": "3.0.0",
    "hapi-auth-jwt2": "11.0.0",
    "hapi-pino": "13.0.0",
    "hapi-pulse": "3.0.1",
    "http-status-codes": "2.3.0",
    "https-proxy-agent": "7.0.6",
    "joi": "18.1.2",
    "jsdom": "^29.0.2",
    "migrate-mongo": "14.0.7",
    "mongo-locks": "3.0.2",
    "mongodb": "7.1.1",
    "node-fetch": "3.3.2",
    "notifications-node-client": "8.3.2",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "proj4": "2.20.4",
    "shapefile": "^0.6.6",
    "undici": "8.0.2"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/preset-env": "7.29.2",
    "@vitest/coverage-v8": "4.1.2",
    "autoprefixer": "10.4.27",
    "eslint": "9.35.0",
    "husky": "9.1.7",
    "neostandard": "0.13.0",
    "nodemon": "3.1.14",
    "npm-run-all": "4.1.5",
    "prettier": "3.8.2",
    "vitest": "4.1.2",
    "vitest-fetch-mock": "0.4.5",
    "vitest-mongodb": "1.0.3"
  },
  "overrides": {
    "vite": "8.0.5",
    "minimatch": "10.2.4",
    "axios": "1.15.0",
    "rollup": "^4.59.0",
    "eslint": {
      "ajv": "^6.14.0"
    },
    "flatted": "^3.4.2",
    "yauzl": "^3.2.1",
    "tinyexec": "1.0.2",
    "fast-xml-parser": "^5.5.7",
    "picomatch": "^2.3.2 || ^4.0.4"
  }
}
